-- BULLET TRACERS
-- ══════════════════════════════════════════════════════════════════════════════

local function updTracers(dt)
    for i = #tracers, 1, -1 do
        local b = tracers[i]
        b.life = b.life - dt
        if b.life <= 0 then
            pcall(function() b.line:Remove() end)
            table.remove(tracers, i)
        else
            local alpha = math.clamp(b.life / b.max, 0, 1)
            pcall(function() b.line.Transparency = alpha end)
        end
    end
end

local function updTracerPos()
    for _, b in ipairs(tracers) do
        pcall(function()
            local f = cam:WorldToViewportPoint(b.oW)
            local t = cam:WorldToViewportPoint(b.hW)
            if f.Z > 0 or t.Z > 0 then
                b.line.From=Vector2.new(f.X,f.Y); b.line.To=Vector2.new(t.X,t.Y); b.line.Visible=true
            else
                b.line.Visible=false
            end
        end)
    end
end

local function fireTracer()
    if not Misc.BTracer or isLobbyVisible() then return end
    local ch = lp.Character
    if not ch then return end
    if getGameTime() - lastTracerFire < cachedWepDelay * 0.8 then return end
    lastTracerFire = getGameTime()
    while #tracers >= 15 do
        local old = table.remove(tracers, 1)
        pcall(function() old.line:Remove() end)
    end
    local camCF = cam.CFrame
    local o = camCF.Position + camCF.LookVector * 2
    local dir = camCF.LookVector * 1000
    local rp = RaycastParams.new(); rp.FilterDescendantsInstances={ch}; rp.FilterType=Enum.RaycastFilterType.Blacklist
    local res = workspace:Raycast(o, dir, rp)
    local hp = res and res.Position or (o + dir)
    local fS = cam:WorldToViewportPoint(o); local tS = cam:WorldToViewportPoint(hp)
    local l = Drawing.new("Line")
    l.From=Vector2.new(fS.X,fS.Y); l.To=Vector2.new(tS.X,tS.Y)
    l.Color=Misc.BTracerCol; l.Thickness=Misc.BTracerThick; l.Transparency=1; l.Visible=true
    table.insert(tracers, {line=l, oW=o, hW=hp, life=Misc.BTracerLife, max=Misc.BTracerLife})
end

