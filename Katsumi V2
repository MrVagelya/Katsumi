local function findAim()
    local best, bestD = nil, math.huge
    local c, camPos = screenCenter, cam.CFrame.Position
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if not aliveCache[p] then continue end
        if not tmOk(p, Aim.Team) then continue end
        local ch = p.Character
        if not ch then continue end
        local pt = ch:FindFirstChild(Aim.Part) or rootCache[p]
        if not pt then continue end
        local dist = (pt.Position - camPos).Magnitude
        if dist > Aim.MaxDist then continue end
        if Aim.Vis and not wallOk(camPos, pt.Position, {lp.Character, ch}) then continue end
        local sp, v = cam:WorldToViewportPoint(pt.Position)
        if not v or sp.Z <= 0 then continue end
        local d = (Vector2.new(sp.X, sp.Y) - c).Magnitude
        if d < bestD and d <= Aim.FOV then best, bestD = p, d end
    end
    return best
end

local function runTrig()
    if not Trig.On or isLobbyVisible() then return end
    if Trig.Hold and not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
    local now = getGameTime()
    local trigDelay = humanDelay(Trig.Delay, Trig.Delay * 0.15)
    if now - lastTrig < trigDelay then return end
    local vp = cam.ViewportSize
    local ray = cam:ViewportPointToRay(vp.X*0.5, vp.Y*0.5)
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {lp.Character}; rp.FilterType = Enum.RaycastFilterType.Blacklist
    local res = workspace:Raycast(ray.Origin, ray.Direction * Trig.MaxDist, rp)
    if not res or not res.Instance then return end
    local mdl = res.Instance:FindFirstAncestorOfClass("Model")
    if not mdl then return end
    local hp = Players:GetPlayerFromCharacter(mdl)
    if not hp or hp == lp then return end
    if not aliveCache[hp] then return end
    if not tmOk(hp, Trig.Team) then return end
    pcall(function() mouse1click() end)
    lastTrig = now
end

