-- ══════════════════════════════════════════════════════════════════════════════

local rBg = Drawing.new("Square"); rBg.Filled=true; rBg.Visible=false
local rBd = Drawing.new("Square"); rBd.Filled=false; rBd.Thickness=1.5; rBd.Visible=false; rBd.Color=Color3.fromRGB(60,60,70)
local rCV = Drawing.new("Line"); rCV.Thickness=1; rCV.Visible=false; rCV.Color=Color3.fromRGB(40,40,50)
local rCH = Drawing.new("Line"); rCH.Thickness=1; rCH.Visible=false; rCH.Color=Color3.fromRGB(40,40,50)
local rLo = Drawing.new("Circle"); rLo.Filled=true; rLo.NumSides=12; rLo.Visible=false

local function updRadar(rc)
    if not Radar.On then
        rBg.Visible, rBd.Visible, rCV.Visible, rCH.Visible, rLo.Visible = false, false, false, false, false
        for _, p in ipairs(Players:GetPlayers()) do
            local e = espC[p]
            if e then e.rDot.Visible, e.rDotO.Visible = false, false end
        end
        return
    end
    local sz, half = Radar.Size, Radar.Size*0.5
    local cx, cy = Radar.X + half, Radar.Y + half
    rBg.Position=Vector2.new(Radar.X,Radar.Y); rBg.Size=Vector2.new(sz,sz); rBg.Color=Radar.BgCol; rBg.Transparency=0.4; rBg.Visible=true
    rBd.Position=Vector2.new(Radar.X,Radar.Y); rBd.Size=Vector2.new(sz,sz); rBd.Visible=true
    rCV.From=Vector2.new(cx,Radar.Y); rCV.To=Vector2.new(cx,Radar.Y+sz); rCV.Visible=true
    rCH.From=Vector2.new(Radar.X,cy); rCH.To=Vector2.new(Radar.X+sz,cy); rCH.Visible=true
    rLo.Position=Vector2.new(cx,cy); rLo.Radius=3; rLo.Color=Radar.LocalCol; rLo.Visible=true
    local lr = rootCache[lp]
    if not lr then return end
    local rv, lv = cam.CFrame.RightVector, cam.CFrame.LookVector
    for _, p in ipairs(Players:GetPlayers()) do
        local e = espC[p]
        if not e or p == lp or not aliveCache[p] then
            if e then e.rDot.Visible, e.rDotO.Visible = false, false end
            continue
        end
        local r = rootCache[p]
        if not r then e.rDot.Visible, e.rDotO.Visible = false, false; continue end
        local rel = r.Position - lr.Position
        local dR, dF = rel.X*rv.X + rel.Z*rv.Z, rel.X*lv.X + rel.Z*lv.Z
        local px = math.clamp(dR/Radar.Scale, -half+Radar.DotR+2, half-Radar.DotR-2)
        local pz = math.clamp(dF/Radar.Scale, -half+Radar.DotR+2, half-Radar.DotR-2)
        local dp = Vector2.new(cx+px, cy-pz)
        e.rDot.Position=dp; e.rDot.Radius=Radar.DotR; e.rDot.Color=RB.On and rc or Radar.DotCol; e.rDot.Visible=true
        e.rDotO.Position=dp; e.rDotO.Radius=Radar.DotR+1; e.rDotO.Visible=true
    end
end

