local function killEsp(p)
    local e = espC[p]
    if not e then return end
    for _, k in ipairs({"boxO","box","name","dist","wpn","hpBg","hpF","trO","tr","rDot","rDotO"}) do
        if e[k] then pcall(function() e[k]:Remove() end) end
    end
    for _, l in ipairs(e.sk) do pcall(function() l:Remove() end) end
    if e.hl then pcall(function() e.hl:Destroy() end) end
    espC[p], aliveCache[p], rootCache[p], teamIdCache[p] = nil, nil, nil, nil
end

local function hideEsp(p)
    local e = espC[p]
    if not e then return end
    for _, k in ipairs({"boxO","box","name","dist","wpn","hpBg","hpF","trO","tr"}) do
        if e[k] then e[k].Visible = false end
    end
    for _, l in ipairs(e.sk) do l.Visible = false end
    e.smoothX, e.smoothY, e.smoothW, e.smoothH = nil, nil, nil, nil
end

local function addHL(p)
    local e = espC[p]
    if not e or e.hl then return end
    local c = p.Character
    if not c then return end
    local h = Instance.new("Highlight")
    h.Adornee = c
    h.FillColor = ESP.ChamsCol
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    h.FillTransparency = ESP.ChamsFillTrans
    h.OutlineTransparency = ESP.ChamsOutlineTrans
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent = c
    e.hl = h
end

local function rmHL(p)
    local e = espC[p]
    if not e or not e.hl then return end
    pcall(function() e.hl:Destroy() end)
    e.hl = nil
end

local function updEsp(p, rc)
    local e = espC[p]
    if not e or not ESP.On or p == lp then
        if e then hideEsp(p); if e.hl then rmHL(p) end end
        return
    end
    
    if ESP.Team and not tmOk(p, true) then
        if e then hideEsp(p); if e.hl then rmHL(p) end end
        return
    end
    
    if not aliveCache[p] then
        if e then hideEsp(p) end
        return
    end
    
    local hrp, hum = rootCache[p], p.Character and p.Character:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then hideEsp(p); return end
    
    local camPos = cam.CFrame.Position
    local d3 = (hrp.Position - camPos).Magnitude
    if d3 > ESP.MaxDist then hideEsp(p); return end
    
    local headPos = hrp.Position + Vector3.new(0,1.5,0)
    local legPos = hrp.Position - Vector3.new(0,2.5,0)
    local tS, tOn = cam:WorldToViewportPoint(headPos)
    local bS, bOn = cam:WorldToViewportPoint(legPos)
    if (not tOn and not bOn) or tS.Z <= 0 then hideEsp(p); return end
    
    local rawH = math.abs(bS.Y - tS.Y)
    local rawW = rawH * 0.45
    local rawCX = (tS.X + bS.X) * 0.5
    local rawTY = math.min(tS.Y, bS.Y)
    local rawBPX = rawCX - rawW * 0.5
    local lerpF = ESP.BoxSmooth
    
    if e.smoothX == nil then
        e.smoothX, e.smoothY, e.smoothW, e.smoothH = rawBPX, rawTY, rawW, rawH
    else
        e.smoothX = e.smoothX + (rawBPX - e.smoothX) * lerpF
        e.smoothY = e.smoothY + (rawTY - e.smoothY) * lerpF
        e.smoothW = e.smoothW + (rawW - e.smoothW) * lerpF
        e.smoothH = e.smoothH + (rawH - e.smoothH) * lerpF
    end
    
    local bP = Vector2.new(math.floor(e.smoothX), math.floor(e.smoothY))
    local bSz = Vector2.new(math.floor(e.smoothW), math.floor(e.smoothH))
    local cX = math.floor(e.smoothX + e.smoothW * 0.5)
    local tY = math.floor(e.smoothY)
    local bH = math.floor(e.smoothH)
    local bc, nc, tc = RB.On and rc or ESP.BoxCol, RB.On and rc or ESP.NameCol, RB.On and rc or ESP.TracerCol
    local ts = ESP.TxtSize
    
    if ESP.Boxes then
        e.boxO.Position = bP - Vector2.new(1,1)
        e.boxO.Size = bSz + Vector2.new(2,2)
        e.boxO.Visible = true
        
        e.box.Position = bP
        e.box.Size = bSz
        e.box.Color = bc
        e.box.Visible = true
    else
        e.boxO.Visible, e.box.Visible = false, false
    end
    
    if ESP.Names then
        e.name.Text = p.DisplayName
        e.name.Position = Vector2.new(cX, tY - ts - 2)
        e.name.Color = nc
        e.name.Size = ts
        e.name.Visible = true
    else
        e.name.Visible = false
    end
    
    if ESP.Weapon then
        local now = getGameTime()
        if now - e.lastWpnCheck > 0.5 then
            e.cachedWpn = plrWeapon(p) or "None"
            e.lastWpnCheck = now
        end
        e.wpn.Text = "[" .. e.cachedWpn .. "]"
        e.wpn.Position = Vector2.new(cX, tY + bH + 2)
        e.wpn.Color = Color3.new(0.9,0.9,0.5)
        e.wpn.Size = ts - 1
        e.wpn.Visible = true
    else
        e.wpn.Visible = false
    end
    
    if ESP.Dist then
        local dy = tY + bH + (ESP.Weapon and (ts + 2) or 2)
        e.dist.Text = "[" .. math.floor(d3) .. "]"
        e.dist.Position = Vector2.new(cX, dy)
        e.dist.Color = Color3.new(0.78,0.78,0.78)
        e.dist.Size = ts - 1
        e.dist.Visible = true
    else
        e.dist.Visible = false
    end
    
    if ESP.HP then
        local bw, bx = 2, bP.X - 5
        e.hpBg.Position = Vector2.new(bx - 1, tY - 1)
        e.hpBg.Size = Vector2.new(bw + 2, bH + 2)
        e.hpBg.Visible = true
        
        local f = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        local fH = bH * f
        e.hpF.Position = Vector2.new(bx, tY + bH - fH)
        e.hpF.Size = Vector2.new(bw, fH)
        e.hpF.Color = hpCol(f)
        e.hpF.Visible = true
    else
        e.hpBg.Visible, e.hpF.Visible = false, false
    end
    
    if ESP.Tracers then
        local vx, vy = cam.ViewportSize.X * 0.5, cam.ViewportSize.Y
        local og = ESP.TracerOrig == "Bottom" and Vector2.new(vx, vy) or ESP.TracerOrig == "Center" and Vector2.new(vx, vy*0.5) or Vector2.new(vx, 0)
        local dst = Vector2.new(cX, tY + bH)
        e.trO.From, e.trO.To, e.trO.Visible = og, dst, true
        e.tr.From, e.tr.To, e.tr.Color, e.tr.Visible = og, dst, tc, true
    else
        e.trO.Visible, e.tr.Visible = false, false
    end
    
    if ESP.Chams then
        if not e.hl then addHL(p) end
        if e.hl then
            e.hl.FillColor = RB.On and rc or ESP.ChamsCol
            e.hl.FillTransparency = ESP.ChamsFillTrans
            e.hl.OutlineTransparency = ESP.ChamsOutlineTrans
        end
    else
        if e.hl then rmHL(p) end
    end
    
    if ESP.Skel then
        for i, b in ipairs(BONES) do
            local p1, p2 = p.Character:FindFirstChild(b[1]), p.Character:FindFirstChild(b[2])
            if p1 and p2 then
                local s1, v1 = cam:WorldToViewportPoint(p1.Position)
                local s2, v2 = cam:WorldToViewportPoint(p2.Position)
                if v1 and v2 and s1.Z > 0 and s2.Z > 0 then
                    e.sk[i].From = Vector2.new(s1.X, s1.Y)
                    e.sk[i].To = Vector2.new(s2.X, s2.Y)
                    e.sk[i].Color = RB.On and rc or Color3.new(1,1,1)
                    e.sk[i].Visible = true
                else
                    e.sk[i].Visible = false
                end
            else
                e.sk[i].Visible = false
            end
        end
    else
        for i = 1, 10 do e.sk[i].Visible = false end
    end
end

local function rebuildEspQueue()
    espUpdateQueue = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then table.insert(espUpdateQueue, p) end
    end
    espUpdateIndex = 1
end

local function runBatchedEsp(rc)
    if #espUpdateQueue == 0 then return end
    if not ESP.On then
        local count = 0
        while count < ESP_UPDATES_PER_FRAME do
            if espUpdateIndex > #espUpdateQueue then espUpdateIndex = 1; break end
            local p = espUpdateQueue[espUpdateIndex]
            if p then hideEsp(p); if espC[p] and espC[p].hl then rmHL(p) end end
            espUpdateIndex = espUpdateIndex + 1
            count = count + 1
        end
        return
    end
    local count = 0
    while count < ESP_UPDATES_PER_FRAME do
        if espUpdateIndex > #espUpdateQueue then espUpdateIndex = 1; break end
        local p = espUpdateQueue[espUpdateIndex]
        if p and Players:FindFirstChild(p.Name) then updEsp(p, rc) end
        espUpdateIndex = espUpdateIndex + 1
        count = count + 1
    end
end

