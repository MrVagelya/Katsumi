local function getGameTime()
    return tick()
end

local function humanDelay(base, variance)
    variance = variance or 0.02
    return base + (math.random() - 0.5) * variance
end

local function gradualLerp(current, target, factor, dt)
    factor = math.clamp(factor * dt * 60, 0.01, 1)
    return current + (target - current) * factor
end

local function jitteredValue(base, range)
    return base + (math.random() - 0.5) * range * 2
end

local function safeCall(func, ...)
    local ok, result = pcall(func, ...)
    if not ok then
        task.wait(humanDelay(0.01, 0.005))
        return nil
    end
    return result
end

local gameStateFlags = {
    inCombat = false,
    lastMovementUpdate = 0,
    lastVisibilityCheck = 0,
}

local function updateGameState()
    local now = getGameTime()
    gameStateFlags.lastMovementUpdate = now
    local char = lp.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local speed = hrp.AssemblyLinearVelocity.Magnitude
            gameStateFlags.inCombat = speed > 1
        end
    end
end

