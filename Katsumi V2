local cachedToolName, cachedWepSpeed, cachedWepDelay = nil, 900, 0.1
local lastWeaponRefreshTime = 0

local function refreshWeaponCache()
    local now = getGameTime()
    if now - lastWeaponRefreshTime < humanDelay(0.1, 0.05) then return end
    lastWeaponRefreshTime = now
    local c = lp.Character
    if not c then cachedToolName = nil; cachedWepSpeed = 900; cachedWepDelay = 0.1; return end
    local tool = c:FindFirstChildOfClass("Tool")
    local n = tool and tool.Name or nil
    cachedToolName = n
    if n and WDB[n] then
        cachedWepSpeed = WDB[n].s
        cachedWepDelay = WDB[n].d
    else
        cachedWepSpeed = 900
        cachedWepDelay = 0.1
    end
end

local function hookToolWatch(char)
    if not char then return end
    char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") then
            task.wait(humanDelay(0.05, 0.02))
            refreshWeaponCache()
        end
    end)
    char.ChildRemoved:Connect(function(c)
        if c:IsA("Tool") then
            task.wait(humanDelay(0.03, 0.01))
            refreshWeaponCache()
        end
    end)
    refreshWeaponCache()
end

local function plrWeapon(p)
    if not p or not p.Character then return nil end
    local tool = p.Character:FindFirstChildOfClass("Tool")
    return tool and tool.Name or nil
end

