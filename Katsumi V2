local function alive(p)
    p = p or lp
    return p and aliveCache[p] == true or false
end

local function root(p)
    p = p or lp
    return rootCache[p]
end

local function refreshAliveCache()
    for _, p in ipairs(Players:GetPlayers()) do
        local c = p.Character
        if not c then
            aliveCache[p] = false
            rootCache[p] = nil
        else
            local h = c:FindFirstChildOfClass("Humanoid")
            local hrp = c:FindFirstChild("HumanoidRootPart")
            aliveCache[p] = h and h.Health > 0 and hrp ~= nil
            rootCache[p] = hrp
        end
    end
end

local function isLobbyVisible()
    local now = getGameTime()
    if now - lastLobbyCheck < 2 then return lobbyVisibleCache end
    lastLobbyCheck = now
    local ok, result = pcall(function()
        return lp.PlayerGui.MainGui.MainFrame.Lobby.Currency.Visible == true
    end)
    lobbyVisibleCache = ok and result or false
    return lobbyVisibleCache
end

local function getTeamId(p)
    if not p then return nil end
    local tid
    pcall(function()
        tid = p:GetAttribute("TeamID") or p:GetAttribute("Team") or p:GetAttribute("team") or p:GetAttribute("TeamId")
    end)
    if tid then return tostring(tid) end
    if p.Team then return tostring(p.Team.Name) end
    pcall(function()
        if p.TeamColor then tid = tostring(p.TeamColor) end
    end)
    return tid and tostring(tid) or nil
end

local function refreshTeamCache()
    for _, p in ipairs(Players:GetPlayers()) do
        teamIdCache[p] = getTeamId(p)
    end
end

local function tmOk(p, useTeamCheck)
    if not useTeamCheck then return true end
    if p == lp then return false end
    local myTeam = teamIdCache[lp]
    local theirTeam = teamIdCache[p]
    if not myTeam or not theirTeam then return true end
    if myTeam == theirTeam then return false end
    return true
end

local function wallOk(o, p, ig)
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = ig
    rp.FilterType = Enum.RaycastFilterType.Blacklist
    return workspace:Raycast(o, p - o, rp) == nil
end

local function hpCol(f)
    return Color3.fromHSV(math.clamp(f,0,1)*0.3,1,1)
end

local function sc() return screenCenter end

local function predPos(pt, hrp, predX, predY)
    local p = pt.Position
    if not hrp then return p end
    local v = Vector3.zero
    pcall(function() v = hrp.AssemblyLinearVelocity or hrp.Velocity end)
    local px, py = predX or 1.0, predY or 1.0
    local imperfectX = jitteredValue(px, 0.05)
    local imperfectY = jitteredValue(py, 0.05)
    return p + Vector3.new(v.X*imperfectX*0.05, v.Y*imperfectY*0.05, v.Z*imperfectX*0.05)
end

local function getNearestEnemy(maxDist)
    local hrp = rootCache[lp]
    if not hrp then return nil end
    local best, bestDist = nil, maxDist or 200
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if not aliveCache[p] then continue end
        if not tmOk(p, true) then continue end
        local r = rootCache[p]
        if r then
            local dist = (r.Position - hrp.Position).Magnitude
            if dist < bestDist then bestDist = dist; best = p end
        end
    end
    return best
end

