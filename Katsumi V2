-- CROSSHAIR
-- ══════════════════════════════════════════════════════════════════════════════

local MAX_CH_LINES = 8
local chL, chO = {}, {}
for i = 1, MAX_CH_LINES do
    chL[i] = Drawing.new("Line"); chL[i].Visible = false
    chO[i] = Drawing.new("Line"); chO[i].Visible = false
end
local chD = Drawing.new("Circle"); chD.Filled=true; chD.NumSides=12; chD.Visible=false

local function updCH(rc, dt)
    if not CH.On then
        for i=1,MAX_CH_LINES do chL[i].Visible, chO[i].Visible = false, false end
        chD.Visible = false
        return
    end
    local col = RB.On and rc or CH.Col
    local cx, cy = screenCenter.X, screenCenter.Y
    local g, s, th = CH.Gap, CH.Size, CH.Thick
    if CH.Dynamic then
        pcall(function()
            local r = rootCache[lp]
            if r then
                local sp = Vector3.new(r.AssemblyLinearVelocity.X, 0, r.AssemblyLinearVelocity.Z).Magnitude
                g = g + math.clamp(sp/16, 0, 1) * CH.DynScale * 5
            end
        end)
    end
    if CH.CenterDot then
        chD.Position=Vector2.new(cx,cy); chD.Radius=CH.DotR; chD.Color=col; chD.Visible=true
    else chD.Visible=false end
    if CH.SpinEnabled then
        chSpinAngle = chSpinAngle + CH.SpinSpeed * dt * math.pi * 2
        if chSpinAngle > math.pi*2 then chSpinAngle = chSpinAngle - math.pi*2 end
    else chSpinAngle = 0 end
    local function drawLines(angles, count)
        for i=1,count do
            local angle = angles[i] + chSpinAngle
            local cosA, sinA = math.cos(angle), math.sin(angle)
            if CH.Outline then
                chO[i].From=Vector2.new(cx+cosA*g, cy+sinA*g)
                chO[i].To=Vector2.new(cx+cosA*(g+s), cy+sinA*(g+s))
                chO[i].Color=CH.OutCol; chO[i].Thickness=th+2; chO[i].Visible=true
            else chO[i].Visible=false end
            chL[i].From=Vector2.new(cx+cosA*g, cy+sinA*g)
            chL[i].To=Vector2.new(cx+cosA*(g+s), cy+sinA*(g+s))
            chL[i].Color=col; chL[i].Thickness=th; chL[i].Visible=true
        end
        for i=count+1,MAX_CH_LINES do chL[i].Visible, chO[i].Visible = false, false end
    end
    if CH.Style == "Cross" then drawLines({-math.pi/2, math.pi/2, math.pi, 0}, 4)
    elseif CH.Style == "X" then drawLines({-math.pi/4, math.pi/4, math.pi*3/4, -math.pi*3/4}, 4)
    elseif CH.Style == "Star" then
        local n, a = math.min(CH.Lines, MAX_CH_LINES), {}
        for i=1,n do a[i] = (i-1)*(math.pi*2/n) end
        drawLines(a, n)
    elseif CH.Style == "Circle" then
        local n = math.min(CH.Lines, MAX_CH_LINES)
        for i=1,n do
            local angle = (i-1)*(math.pi*2/n) + chSpinAngle
            local cosA, sinA = math.cos(angle), math.sin(angle)
            local r2 = g + s*0.5
            if CH.Outline then
                chO[i].From=Vector2.new(cx+cosA*r2, cy+sinA*r2)
                chO[i].To=Vector2.new(cx+cosA*(r2+2), cy+sinA*(r2+2))
                chO[i].Color=CH.OutCol; chO[i].Thickness=th+3; chO[i].Visible=true
            else chO[i].Visible=false end
            chL[i].From=Vector2.new(cx+cosA*r2, cy+sinA*r2)
            chL[i].To=Vector2.new(cx+cosA*(r2+2), cy+sinA*(r2+2))
            chL[i].Color=col; chL[i].Thickness=th+1; chL[i].Visible=true
        end
        for i=n+1,MAX_CH_LINES do chL[i].Visible, chO[i].Visible = false, false end
    end
end

