-- ORBIT (FROM SCRIPT 1 - IMPROVED VERSION)
-- ══════════════════════════════════════════════════════════════════════════════

local function startOrbit()
    if orbitConn then orbitConn:Disconnect() end
    orbitAngle = 0

    orbitConn = RunService.Heartbeat:Connect(function(dt)
        if not Misc.Orbit then return end

        local char = lp.Character
        if not char then return end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then return end

        local enemy = getNearestEnemy(200)
        
        if enemy then
            orbitTarget = enemy
        end
        
        if not orbitTarget or not aliveCache[orbitTarget] then
            orbitTarget = nil
            return
        end

        local eHRP = rootCache[orbitTarget]
        if not eHRP then 
            orbitTarget = nil
            return 
        end

        orbitAngle = orbitAngle + dt * Misc.OrbitSpeed * 2

        local ePos = eHRP.Position
        local eVel = Vector3.zero
        pcall(function() eVel = eHRP.AssemblyLinearVelocity end)
        
        local predictedPos = ePos + (eVel * 0.1)
        
        local x = math.cos(orbitAngle) * Misc.OrbitRadius
        local z = math.sin(orbitAngle) * Misc.OrbitRadius
        local targetPos = predictedPos + Vector3.new(x, Misc.OrbitHeight, z)

        local smoothFactor = math.clamp(12 * dt, 0.1, 0.95)
        local newPos = hrp.Position:Lerp(targetPos, smoothFactor)
        
        local lookPos = Vector3.new(predictedPos.X, newPos.Y, predictedPos.Z)
        hrp.CFrame = CFrame.lookAt(newPos, lookPos)
        
        local velocityDirection = (targetPos - hrp.Position).Unit
        hrp.AssemblyLinearVelocity = velocityDirection * (Misc.OrbitRadius * Misc.OrbitSpeed * 2)
    end)
end

local function stopOrbit()
    if orbitConn then orbitConn:Disconnect(); orbitConn = nil end
    orbitTarget = nil
    pcall(function()
        local char = lp.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
        end
    end)
end

