-- RAGEBOT (FIXED & DEBUGGED)
-- ══════════════════════════════════════════════════════════════════════════════

local rageDebugMode = false  -- Set to true for debug prints

local function rageShouldShoot(enemyChar, myChar)
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local targetHead = enemyChar and enemyChar:FindFirstChild("Head")
    if not myHRP or not targetHead then return false end
    
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {myChar}
    rp.FilterType = Enum.RaycastFilterType.Blacklist
    
    local direction = (targetHead.Position - myHRP.Position)
    local result = workspace:Raycast(myHRP.Position, direction, rp)
    
    if result and result.Instance then
        local hitModel = result.Instance:FindFirstAncestorOfClass("Model")
        if hitModel and hitModel == enemyChar then
            return true
        end
    end
    return false
end

local function startRagebot()
    if rageConn then rageConn:Disconnect() end
    rageAngle = 0
    
    if rageDebugMode then
        print("[Ragebot] Starting ragebot...")
    end
    
    rageConn = RunService.Heartbeat:Connect(function(dt)
        if not Rage.On then return end
        
        local myChar = lp.Character
        local hrp = myChar and rootCache[lp]
        local hum = myChar and myChar:FindFirstChildOfClass("Humanoid")
        
        if not hrp or not hum or hum.Health <= 0 then 
            if rageDebugMode and frame % 60 == 0 then
                print("[Ragebot] Player not alive or no HRP")
            end
            return 
        end
        
        if isLobbyVisible() then return end
        
        -- Find nearest enemy with proper team check
        local enemy = nil
        local bestDist = Rage.MaxTrackDist
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p == lp then continue end
            if not aliveCache[p] then continue end
            if Rage.Team and not tmOk(p, true) then continue end
            
            local r = rootCache[p]
            if r then
                local dist = (r.Position - hrp.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    enemy = p
                end
            end
        end
        
        if not enemy then 
            if rageDebugMode and frame % 120 == 0 then
                print("[Ragebot] No enemy found")
            end
            return 
        end
        
        local eHRP = rootCache[enemy]
        if not eHRP then return end
        
        if rageDebugMode and frame % 60 == 0 then
            print(string.format("[Ragebot] Tracking: %s, Dist: %.1f", enemy.DisplayName, bestDist))
        end
        
        -- Strafe behind enemy
        if Rage.StrafeBehind then
            local eVel = Vector3.zero
            pcall(function() eVel = eHRP.AssemblyLinearVelocity end)
            local predictedPos = eHRP.Position + (eVel * Rage.Prediction)
            local eLook = eHRP.CFrame.LookVector
            
            rageAngle = rageAngle + dt * Rage.StrafeSpeed
            local offset = CFrame.Angles(0, rageAngle, 0) * Vector3.new(0, 0, Rage.StrafeRadius)
            local targetPos = predictedPos + (-eLook) * Rage.StrafeRadius + Vector3.new(offset.X, 2, offset.Z) * 0.3
            
            local smoothFactor = math.clamp(Rage.StrafeSmooth * dt, 0.1, 1)
            local newPos = hrp.Position:Lerp(targetPos, smoothFactor)
            hrp.CFrame = CFrame.lookAt(newPos, Vector3.new(predictedPos.X, newPos.Y, predictedPos.Z))
        end
        
        -- Auto shoot
        if Rage.AutoShoot then
            local now = getGameTime()
            local shotDelay = humanDelay(cachedWepDelay, cachedWepDelay * 0.1)
            
            if now - lastRageShot < shotDelay then return end
            
            local enemyChar = enemy.Character
            if not enemyChar then return end
            
            if rageShouldShoot(enemyChar, myChar) then
                lastRageShot = now
                
                if rageDebugMode then
                    print("[Ragebot] SHOOTING at " .. enemy.DisplayName)
                end
                
                pcall(function()
                    mouse1press()
                    task.delay(humanDelay(0.03, 0.01), function()
                        mouse1release()
                    end)
                end)
            end
        end
    end)
    
    print("[Ragebot] Ragebot connection established")
end

local function stopRagebot()
    if rageConn then 
        rageConn:Disconnect()
        rageConn = nil
        print("[Ragebot] Stopped")
    end
end

