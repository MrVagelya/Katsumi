RunService.RenderStepped:Connect(function(dt)
    cam = workspace.CurrentCamera
    frame = frame + 1
    screenCenter = Vector2.new(cam.ViewportSize.X * 0.5, cam.ViewportSize.Y * 0.5)
    
    if RB.On then rbHue = (rbHue + dt * RB.Speed * 0.5) % 1 end
    local rc = RB.On and Color3.fromHSV(rbHue, 1, 1) or Color3.new(1,1,1)
    local c = screenCenter
    
    updateFOVCircle()
    
    if Misc.FOVChanger then applyFOV() end
    if frame % 60 == 0 and Move.JumpBoost then applyJumpBoost() end
    
    if Aim.On and not isLobbyVisible() then
        if rmbDown then
            local tgt = Aim.Mode == "LockOn" and (aimLocked and aliveCache[aimLocked] and aimLocked or (function() aimLocked = findAim(); return aimLocked end)()) or findAim()
            if tgt and tgt.Character then
                local ch = tgt.Character
                local pt = ch:FindFirstChild(Aim.Part) or rootCache[tgt]
                if pt then
                    local hrpE = rootCache[tgt]
                    local ap = Aim.Pred and predPos(pt, hrpE) or pt.Position
                    local sp, v = cam:WorldToViewportPoint(ap)
                    if v and sp.Z > 0 then
                        local dx, dy = sp.X - c.X, sp.Y - c.Y
                        if Aim.Sticky and prevAimScr then
                            local bl = prevAimScr:Lerp(Vector2.new(sp.X, sp.Y), 1 - Aim.StickyF)
                            dx, dy = bl.X - c.X, bl.Y - c.Y
                            prevAimScr = bl
                        else prevAimScr = Vector2.new(sp.X, sp.Y) end
                        if Aim.Shake then
                            dx = dx + (math.random()-0.5)*Aim.ShakeAmt*2
                            dy = dy + (math.random()-0.5)*Aim.ShakeAmt*2
                        end
                        if math.abs(dx) >= 1 or math.abs(dy) >= 1 then
                            local sm = math.max(1, Aim.Smooth)
                            local imperfectSmooth = sm + jitteredValue(0, sm * 0.05)
                            local moveX, moveY = dx/imperfectSmooth, dy/imperfectSmooth
                            if math.abs(moveX) > math.abs(dx) then moveX = dx end
                            if math.abs(moveY) > math.abs(dy) then moveY = dy end
                            pcall(function() mousemoverel(moveX, moveY) end)
                        end
                    end
                end
            end
        else prevAimScr = nil end
    elseif not Aim.On then aimLocked, prevAimScr = nil, nil end
    
    if mDown and not isLobbyVisible() and aliveCache[lp] and Misc.BTracer then fireTracer() end
    runTrig()
    runBatchedEsp(rc)
    
    updRadar(rc)
    updCH(rc, dt)
    updFly()
    if frame % 2 == 0 then updTracers(dt); updTracerPos() end
end)

