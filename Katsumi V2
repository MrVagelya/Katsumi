-- ANTI-AIM WITH RANDOM PITCH
-- ══════════════════════════════════════════════════════════════════════════════

local AntiAim = {}

function AntiAim.Start()
    if aaConn then aaConn:Disconnect() end
    aaConn = RunService.Heartbeat:Connect(function()
        if not AA.Enabled then return end
        local char = lp.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then return end
        
        local pos = hrp.Position
        local camLook = cam.CFrame.LookVector
        local baseYaw = math.atan2(-camLook.X, -camLook.Z)
        local finalYaw = baseYaw
        
        -- Yaw calculation
        if AA.Mode == "Static" then
            finalYaw = baseYaw + math.rad(AA.Static.Angle)
        elseif AA.Mode == "Spin" then
            AA.Spin.CurrentAngle = (AA.Spin.CurrentAngle + AA.Spin.Speed) % 360
            finalYaw = math.rad(AA.Spin.CurrentAngle)
        elseif AA.Mode == "Jitter" then
            local now = getGameTime()
            if now - AA.Jitter.LastSwitch >= AA.Jitter.Speed then
                AA.Jitter.Direction = AA.Jitter.Direction * -1
                AA.Jitter.LastSwitch = now
            end
            finalYaw = baseYaw + math.rad(AA.Jitter.Angle * AA.Jitter.Direction)
        elseif AA.Mode == "Strafe" then
            local vel = hrp.AssemblyLinearVelocity
            local moving = Vector3.new(vel.X, 0, vel.Z).Magnitude > 1
            if moving then
                local moveDir = Vector3.new(vel.X, 0, vel.Z).Unit
                local dot = moveDir:Dot(hrp.CFrame.LookVector)
                finalYaw = baseYaw + (dot < 0 and math.rad(AA.Strafe.Angle) or -math.rad(AA.Strafe.Angle))
            else
                finalYaw = baseYaw + math.rad(AA.Static.Angle)
            end
        end
        
        -- Pitch calculation with RANDOM option
        local pitchRad = 0
        if AA.Pitch.Enabled then
            if AA.Pitch.Random then
                -- Random pitch that changes rapidly
                local now = getGameTime()
                local updateInterval = 1 / AA.Pitch.Speed  -- Speed controls how fast it changes
                
                if now - AA.Pitch.LastUpdate >= updateInterval then
                    -- Generate new random pitch value (0-360 degrees)
                    AA.Pitch.CurrentValue = math.random(0, 360)
                    AA.Pitch.LastUpdate = now
                end
                
                pitchRad = math.rad(AA.Pitch.CurrentValue)
            else
                -- Normal static pitch
                pitchRad = math.rad(AA.Pitch.Value)
            end
        end
        
        hrp.CFrame = CFrame.new(pos) * CFrame.Angles(pitchRad, finalYaw, 0)
    end)
end

function AntiAim.Stop()
    if aaConn then aaConn:Disconnect(); aaConn = nil end
    AA.Enabled = false
end

