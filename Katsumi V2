        touchActive = true
        touchPos = inp.Position
    end
end)

UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then mDown = false end
    if inp.KeyCode == Enum.KeyCode.W then flyKeys.W = false end
    if inp.KeyCode == Enum.KeyCode.S then flyKeys.S = false end
    if inp.KeyCode == Enum.KeyCode.A then flyKeys.A = false end
    if inp.KeyCode == Enum.KeyCode.D then flyKeys.D = false end
    if inp.KeyCode == Enum.KeyCode.Space then flyKeys.Space = false end
    if inp.KeyCode == Enum.KeyCode.LeftShift then flyKeys.LeftShift = false end
    if inp.UserInputType == Enum.UserInputType.MouseButton2 then rmbDown = false end
    if inp.UserInputType == Enum.UserInputType.Touch then
        touchActive = false
        touchPos = nil
    end
end)

UIS.InputChanged:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch and touchActive then
        touchPos = inp.Position
    end
end)

local function updFly()
    if not Move.Fly or not flyBV or not flyBG then return end
    local cf = cam.CFrame
    local d = Vector3.zero
    if flyKeys.W then d = d + cf.LookVector end
    if flyKeys.S then d = d - cf.LookVector end
    if flyKeys.A then d = d - cf.RightVector end
    if flyKeys.D then d = d + cf.RightVector end
    if flyKeys.Space then d = d + Vector3.yAxis end
    if flyKeys.LeftShift then d = d - Vector3.yAxis end
    if touchActive and touchPos then
        local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        local delta = touchPos - center
        local magnitude = math.min(delta.Magnitude, 200)
        if magnitude > 50 then
            local normalized = delta.Unit
            d = d + (cf.LookVector * normalized.Y + cf.RightVector * normalized.X) * (magnitude/100)
        end
    end
    if d.Magnitude > 0 then d = d.Unit end
    flyBV.Velocity = d * Move.FlySpd
    flyBG.CFrame = cf
end

local function startNoclip()
    if nclipC then nclipC:Disconnect() end
    nclipC = RunService.Stepped:Connect(function()
        if not Move.Noclip then return end
        local c = lp.Character
        if not c then noclipParts = {}; return end
        if #noclipParts == 0 then
            for _, p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") then
                    table.insert(noclipParts, p)
                end
            end
        end
        for _, p in ipairs(noclipParts) do
            if p and p.Parent then
                p.CanCollide = false
            end
        end
    end)
end

local function stopNoclip()
    if nclipC then nclipC:Disconnect(); nclipC = nil end
    noclipParts = {}
end

